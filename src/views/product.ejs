<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Fabric Shop</title>
  </head>
  <body>
    <%- include("partials/header") %>
    <h2>Products</h2>
    <%- include("partials/product-header") %>
    <h2>Add new product</h2>
    <p>Fill the form below to add a new category</p>
    <section>
      <h3>New Product</h3>
      <div>
        <form action="/category/new" method="post">
          <label for="category-name">Name: </label>
          <input
            type="text"
            name="category-name"
            id="category-name"
            value="<%= locals.prev && prev['category-name'] %>"
            required
          />
          <button type="submit">Create</button>
        </form>
        <%- include("partials/product-errors") %>
      </div>
    </section>
  </body>
</html>

<main>
  <h2>Category detail</h2>
  <form style="display: contents" action="/category/<%= category.categoryId %>/delete" method="post">
    <button type="submit" style="background: red; color: #fff" onclick="return confirm('Are you sure?');">
      Delete
    </button>
  </form>
  <a style="text-decoration: none" href="/category/<%= category.categoryId %>/update">
    <button>Edit</button>
  </a>
  <p>
    <span style="font-weight: bold">Category name:</span>
    <%= category.name %>
  </p>
  <p>
    <span style="font-weight: bold">Category ID:</span>
    <%= category.categoryId %>
  </p>
  <p>
    <span style="font-weight: bold">Added at:</span>
    <%= category.createdAt %>
  </p>
  <p><span style="font-weight: bold">Products</span></p>
  <ul>
    <% products.forEach(product => { %>
    <li><%= product.name %></li>
    <% }) %>
  </ul>
</main>
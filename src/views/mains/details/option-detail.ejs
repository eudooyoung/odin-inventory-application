<main class="detail option">
  <h2>Option detail</h2>
  <div class="buttons">
    <form action="/option/<%= option.optionId %>/delete" method="post">
      <button class="delete" type="submit" onclick="return prompt('Enter admin pw.') === '<%= adminPw %>';">
        Delete
      </button>
    </form>
    <a href="/option/<%= option.optionId %>/update">
      <button>Edit</button>
    </a>
  </div>
  <div class="information">
    <p>
      <span>Option name:</span>
      <%= option.name %>
    </p>
    <p>
      <span>Option ID:</span>
      <%= option.optionId %>
    </p>
    <p><span>Price</span>
      <%= option.price %>
    </p>
    <p>
      <span>Added at:</span>
      <%= option.createdAt %>
    </p>
  </div>
</main>
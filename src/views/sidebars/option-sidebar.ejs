<section class=".sidebar option">
  <h2>Options</h2>
  <% if (locals.options) { %>
  <ul>
    <% options.forEach(option => { %>
    <li>
      <a class="<%= locals.option?.optionId === option.optionId && 'selected' %>" href="/option/<%= option.optionId %>"><%= option.name %></a>
    </li>
    <% }) %>
  </ul>
  <% } %>
</section>
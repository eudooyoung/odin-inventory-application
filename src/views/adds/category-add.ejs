<main>
  <h2>Add new category</h2>
  <p>Fill the form below to add a new category</p>
  <section>
    <h3>New Category</h3>
    <div>
      <form action="/category/new" method="post">
        <label for="category-name">Name: </label>
        <input
          type="text"
          name="category-name"
          id="category-name"
          value="<%= locals.prev && prev['category-name'] %>"
          required
        />
        <button type="submit">Create</button>
      </form>
      <%- include("../errors/category-errors") %>
    </div>
  </section>
</main>
